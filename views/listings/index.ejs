<% layout("/layouts/boilerplate") %>

<style>
/* Filters */
#filters {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 1rem;
}

.filter {
  text-align: center;
  padding: 0.5rem 1rem;
  border-radius: 10px;
  transition: 0.3s;
  opacity: 0.7;
}

.filter:hover {
  opacity: 1;
  cursor: pointer;
  background-color: #f1f1f1;
}

/* Tax toggle */
.tax-toggle {
  border: 1.5px solid #ccc;
  height: 3rem;
  border-radius: 1rem;
  display: flex;
  align-items: center;
  padding: 0 1rem;
}

/* Cards */
.l-card {
  border-radius: 15px;
  overflow: hidden;
  border: none;
  transition: all 0.3s ease;
  background-color: #fff;
}

.l-card:hover {
  transform: scale(1.03);
  box-shadow: 0 4px 20px rgba(0,0,0,0.15);
}

/* Image */
.card-img-top {
  width: 100%;
  height: 18rem;
  object-fit: cover;
}

/* Remove link style */
.listing-link {
  text-decoration: none;
  color: inherit;
}

/* Text */
.card-text {
  font-size: 0.95rem;
}

/* Tax text */
.text {
  display: none;
  color: gray;
  font-size: 0.85rem;
}
</style>

<!-- Filters -->
<div id="filters" class="mb-3">
  <div class="filter"><i class="fa-solid fa-fire"></i><p>Trending</p></div>
  <div class="filter"><i class="fa-solid fa-bed"></i><p>Rooms</p></div>
  <div class="filter"><i class="fa-solid fa-umbrella-beach"></i><p>Beach</p></div>
  <div class="filter"><i class="fa-solid fa-mountain"></i><p>Mountain</p></div>
  <div class="filter"><i class="fa-solid fa-water-ladder"></i><p>Pools</p></div>
  <div class="filter"><i class="fa-solid fa-mountain-city"></i><p>Cities</p></div>
  <div class="filter"><i class="fa-regular fa-house"></i><p>Farms</p></div>
  <div class="filter"><i class="fa-solid fa-snowflake"></i><p>Arctic</p></div>
  <div class="filter"><i class="fa-solid fa-campground"></i><p>Camping</p></div>

  <div class="tax-toggle ms-auto">
    <div class="form-check form-switch">
      <input class="form-check-input" type="checkbox" id="taxSwitch">
      <label class="form-check-label" for="taxSwitch">
        Display total after taxes
      </label>
    </div>
  </div>
</div>

<!-- Listings -->
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">

  <% if (!listings || listings.length === 0) { %>
    <h4>No listings available</h4>
  <% } %>

  <% listings.forEach(listing => { %>

    <div class="col">
      <a href="/listings/<%= listing._id %>" class="listing-link">
        
        <div class="card l-card">
          
          <!-- Image -->
          <img 
            src="<%= listing.image?.url || 'https://via.placeholder.com/400' %>" 
            class="card-img-top" 
            alt="listing image"
          />

          <!-- Content -->
          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b><br>

              ₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> / night
              
              <span class="text">
                (₹ <%= listing.price ? (listing.price * 1.18).toLocaleString("en-IN") : "" %> with tax)
              </span>
            </p>
          </div>

        </div>

      </a>
    </div>

  <% }) %>

</div>

<!-- Script -->
<script>
  const taxSwitch = document.getElementById("taxSwitch");

  if (taxSwitch) {
    taxSwitch.addEventListener("change", () => {
      const taxInfo = document.querySelectorAll(".text");

      taxInfo.forEach(info => {
        info.style.display = taxSwitch.checked ? "inline" : "none";
      });
    });
  }
</script>