<% layout("/layouts/boilerplate") %>
<div class="container mt-5">

  <!-- ================= TITLE ================= -->
  <div class="row mb-3">
    <div class="col-md-8 offset-md-2">
      <h2 class="fw-bold"><%= listing.title %></h2>
    </div>
  </div>

  <!-- ================= LISTING CARD ================= -->
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <div class="card listing-card shadow-lg">

        <!-- IMAGE -->
        <img
          src="<%= listing.image?.url || listing.image %>"
          class="card-img-top show-img"
          alt="listing_image"
        />

        <!-- CONTENT -->
        <div class="card-body px-4 py-3">
          <p class="text-muted mb-2">
            Owned by:
            <span class="fw-semibold">
              <%= listing.owner?.username || "Unknown" %>
            </span>
          </p>

          <p class="card-text mb-3">
            <b><%= listing.title %></b> <br />
            <%= listing.description %>
          </p>

          <div class="mb-2">
            <span class="price fs-5 fw-bold text-danger">
              ₹ <%= listing.price.toLocaleString("en-IN") %> / night
            </span>
          </div>

          <p class="location text-secondary">
            <i class="fa-solid fa-location-dot"></i>
            <%= listing.location %>, <%= listing.country %>
          </p>

          <!-- EDIT & DELETE BUTTONS (only for owner) -->
          <% if (currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
            <div class="btns mt-3 d-flex gap-2">
              <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning">
                ✏️ Edit
              </a>
              <form method="POST"
                action="/listings/<%= listing._id %>?_method=DELETE"
                onsubmit="return confirm('Are you sure you want to delete this listing?');">
                <button type="submit" class="btn btn-danger">
                  🗑️ Delete
                </button>
              </form>
            </div>
          <% } %>

        </div>
      </div>
    </div>
  </div>

  <!-- ================= ADD REVIEW SECTION ================= -->
  <% if (currUser) { %>
    <div class="row mt-5">
      <div class="col-md-8 offset-md-2">
        <h4 class="mb-3">Leave a Review</h4>

        <form action="/listings/<%= listing._id %>/reviews"
              method="POST"
              class="needs-validation"
              novalidate>

          <!-- Rating -->
          <div class="mb-3">
            <label class="form-label">Rating</label>
            <input
              type="range"
              min="1"
              max="5"
              step="1"
              value="3"
              name="review[rating]"
              class="form-range"
              required
              oninput="this.nextElementSibling.querySelector('span').innerText = this.value"
            />
            <small class="text-muted">Rating: <span>3</span> / 5</small>
          </div>

          <!-- Comment -->
          <div class="mb-3">
            <label class="form-label">Comments</label>
            <textarea
              name="review[comment]"
              rows="4"
              class="form-control"
              placeholder="Write your review here..."
              required
            ></textarea>
            <div class="invalid-feedback">
              Please add some comments.
            </div>
          </div>

          <button class="btn btn-dark">Submit</button>
        </form>
      </div>
    </div>
  <% } else { %>
    <p class="text-center text-muted mt-4">
      Please <a href="/login">login</a> to add a review.
    </p>
  <% } %>

  <hr class="my-5" />

  <!-- ================= ALL REVIEWS ================= -->
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <p><b>All Reviews</b></p>
      <div class="row">
        <% for(let review of listing.reviews) { %>
          <div class="card col-5 ms-3 mb-3">
            <div class="card-body">
              <h5 class="card-title">@<%= review.author.username %></h5>
              <p class="card-text"><%= review.comment %></p>
              <p class="card-text"><%= review.rating %> stars</p>

              <!-- DELETE only for review author -->
              <% if (currUser && currUser._id.equals(review.author._id)) { %>
                <form
                  method="POST"
                  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                  <button class="btn btn-sm btn-dark">Delete</button>
                </form>
              <% } %>

            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>

</div>

<!-- Bootstrap Validation Script -->
<script>
  (() => {
    'use strict';
    const forms = document.querySelectorAll('.needs-validation');
    Array.from(forms).forEach(form => {
      form.addEventListener('submit', event => {
        if (!form.checkValidity()) {
          event.preventDefault();
          event.stopPropagation();
        }
        form.classList.add('was-validated');
      }, false);
    });
  })();
</script>