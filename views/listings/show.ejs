<% layout("/layouts/boilerplate") %>

<div class="row mt-3">

  <h3 class="text-center">Listing Details</h3>

  <div class="card col-6 offset-3 show-card mt-3">

    <!-- Image -->
    <img
      src="<%= listing.image.url %>"
      class="card-img-top show-img"
      alt="listing_image"
    >

    <!-- Card Body -->
    <div class="card-body">

      <!-- Title -->
      <h4 class="card-title">
        <%= listing.title %>
      </h4>

      <!-- Description -->
      <p class="card-text">
        <%= listing.description %>
      </p>

      <!-- Price -->
      <p class="price">
        ₹ <%= listing.price.toLocaleString("en-IN") %> / night
      </p>

      <!-- Location -->
      <p>
        <%= listing.location %>
      </p>

      <!-- Country -->
      <p>
        <%= listing.country %>
      </p>

      <!-- Buttons -->
      <div class="btns mt-3">

        <a
          href="/listings/<%= listing._id %>/edit"
          class="btn btn-danger"
        >
          Edit
        </a>

        <form
          method="POST"
          action="/listings/<%= listing._id %>?_method=DELETE"
          style="display:inline;"
        >

          <button class="btn btn-dark">
            Delete
          </button>

        </form>

      </div>

    </div>

  </div>

</div>