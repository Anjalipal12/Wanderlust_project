<% layout("/layouts/boilerplate") %>

<div class="container mt-3">
  <div class="card show-card listing-card">
    <h3><%= listing.title %></h3>
    <% if (listing.image?.url) { %>
      <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
    <% } %>

    <div class="card-body">
      <p><b>Owned by:</b> <%= listing.owner?.username || "Unknown" %></p>
      <p><%= listing.description %></p>
      <p>Price: &#8377; <%= listing.price?.toLocaleString("en-IN") || "N/A" %></p>
      <p>Location: <%= listing.location %>, <%= listing.country %></p>
    </div>
  </div>

  <% if (currUser && listing.owner?._id.equals(currUser._id)) { %>
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary mt-2">Edit</a>
    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="mt-2">
      <button class="btn btn-danger">Delete</button>
    </form>
  <% } %>

  <hr>

  <% if (listing.reviews && listing.reviews.length > 0) { %>
    <h4>Reviews</h4>
    <% listing.reviews.forEach(review => { %>
      <div class="card mb-2">
        <div class="card-body">
          <b>@<%= review.author?.username || "Anonymous" %></b>:
          <%= "★".repeat(review.rating) %>
          <p><%= review.body %></p>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <p>No reviews yet.</p>
  <% } %>
</div>